<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coopain.controleur.TourneeController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="LogiSemin - Facturation de la Tournée" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Type de prestation :" />
        <ComboBox fx:id="comboPrestations" prefWidth="200" />
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Nombre d'actes :" />
        <TextField fx:id="txtNbActes" prefWidth="60" text="1" />
    </HBox>

    <Button text="Ajouter l'acte à la tournée" onAction="#handleAjouterActe" style="-fx-background-color: #28a745; -fx-text-fill: white;"/>
    <TextArea fx:id="txtHistorique" editable="false" prefHeight="100" promptText="Aucun acte saisi pour le moment..." />
    <Separator />

    <Label text="Résumé Financier" style="-fx-font-weight: bold;" />
    <Label fx:id="lblTotal" text="CA Total de la tournée : 0.0 €" style="-fx-font-size: 16px; -fx-text-fill: #007bff;" />
    <Label fx:id="lblMessage" textFill="red" />
    
    <Separator />
    <Button text="Nouvelle Tournée" onAction="#handleNouvelleTournee" style="-fx-background-color: #007bff; -fx-text-fill: white;"/>
</VBox>